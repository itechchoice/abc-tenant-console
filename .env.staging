# Public path used by Vite assets and React Router basename.
# Keep "/" for root deployment, or set "/console/" for sub-path deployment.
VITE_APP_BASE_PATH=/

# 给前端 Axios 用的：让前端把请求打给本地 Vite 服务器触发拦截
VITE_API_BASE_URL=/tenant-console-api

# 给 Vite 代理服务器用的：告诉它拦截到 /api 后，转发给哪个真实后端
VITE_PROXY_TARGET=https://arch.stg.alphabitcore.io
